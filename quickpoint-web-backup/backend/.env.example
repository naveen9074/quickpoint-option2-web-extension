# ─── ISERT Backend Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.

# Database: SQLite (default, no setup needed) OR PostgreSQL
DATABASE_URL=sqlite:///./isert.db
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/isert_db

# Whisper model size: tiny | base | small | medium | large
WHISPER_MODEL_SIZE=base

# HuggingFace models (change if you have a faster model locally)
SUMMARIZATION_MODEL=facebook/bart-large-cnn
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# App settings
APP_NAME=ISERT
DEBUG=true
